# Server Configuration
NODE_ENV=development
PORT=8000
CLIENT_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/gamestreaming
DATABASE_POOL_SIZE=20

# WebRTC Configuration
WEBRTC_LISTEN_PORT=50000
WEBRTC_PUBLIC_IP=your-server-ip
WEBRTC_ENABLE_MUXING=true

# ICE Servers (STUN/TURN)
ICE_SERVERS=[{"urls":["stun:stun.l.google.com:19302"]},{"urls":["stun:stun1.l.google.com:19302"]},{"urls":["turn:your-turn-server.com"],"username":"turnuser","credential":"turnpass"}]

# Video Encoding
VIDEO_CODEC=vp8
VIDEO_BITRATE_MIN=500
VIDEO_BITRATE_MAX=20000
VIDEO_FRAMERATE=60
VIDEO_WIDTH=1920
VIDEO_HEIGHT=1080
HARDWARE_ACCELERATION=true
HARDWARE_ENCODER=nvenc

# Audio Encoding
AUDIO_CODEC=opus
AUDIO_BITRATE=128
AUDIO_SAMPLE_RATE=48000

# Authentication
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRY=7d
REFRESH_TOKEN_EXPIRY=30d

# Session Management
SESSION_TIMEOUT=3600
MAX_CONCURRENT_STREAMS=10
MAX_STREAM_DURATION=86400

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# TURN Server
TURN_SERVER=your-turn-server.com
TURN_USERNAME=turnuser
TURN_PASSWORD=turnpass
TURN_PORT=3478

# Redis Cache
REDIS_URL=redis://redis:6379
REDIS_TTL=3600

# Security
CORS_ORIGIN=http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1
REST_API_RATE_LIMIT=100
WS_RATE_LIMIT=500

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
ENABLE_PROFILING=false
